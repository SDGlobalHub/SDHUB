<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SD Hub · Sales Development</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;800&family=Barlow+Condensed:wght@700;800;900&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy: #1B2B6B;
    --navy-dark: #111d4a;
    --navy-mid: #1e3278;
    --navy-light: #2a3e8c;
    --gold: #E8A020;
    --gold-light: #f5b940;
    --gold-pale: #FEF3DC;
    --white: #ffffff;
    --gray-50: #f8f8f5;
    --gray-100: #f0efe8;
    --gray-400: #9a9990;
    --gray-600: #5f5e58;
    --text: #1a1a18;
    --radius: 10px;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Barlow', sans-serif;
    background: var(--gray-50);
    color: var(--text);
    min-height: 100vh;
  }

  /* ── NAV ── */
  .site-header {
    background: var(--navy);
    padding: 0 2.5rem;
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 52px;
    border-bottom: 2px solid var(--gold);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .site-logo {
    background: var(--gold);
    color: var(--navy);
    font-weight: 800;
    font-size: 13px;
    letter-spacing: 0.5px;
    padding: 4px 10px;
    border-radius: 4px;
    white-space: nowrap;
    text-decoration: none;
  }

  .site-nav { display: flex; gap: 0; overflow-x: auto; }

  .site-nav a {
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    padding: 0 1rem;
    height: 52px;
    display: flex;
    align-items: center;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    transition: color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }

  .site-nav a:hover { color: white; }
  .site-nav a.active { color: var(--gold); border-bottom-color: var(--gold); }

  /* ── HERO ── */
  .hero {
    background: var(--navy);
    position: relative;
    overflow: hidden;
    padding: 5rem 2.5rem 4rem;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 80% at 80% 50%, rgba(232,160,32,0.08) 0%, transparent 70%),
      radial-gradient(ellipse 40% 60% at 10% 80%, rgba(255,255,255,0.03) 0%, transparent 60%);
  }

  .hero-grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
  }

  .hero-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
  }

  .hero h1 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(52px, 7vw, 88px);
    font-weight: 900;
    line-height: 0.9;
    color: var(--white);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .hero h1 span { color: var(--gold); display: block; }

  .hero-desc {
    color: rgba(255,255,255,0.7);
    font-size: 15px;
    line-height: 1.65;
    max-width: 440px;
    margin-bottom: 2.5rem;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--gold);
    color: var(--navy);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.5px;
    padding: 12px 24px;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.15s, transform 0.15s;
  }

  .hero-cta:hover { background: var(--gold-light); transform: translateY(-1px); }

  .hero-visual {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .hero-stat-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .hero-stat {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    padding: 20px;
    transition: background 0.2s;
  }

  .hero-stat:hover { background: rgba(255,255,255,0.1); }

  .hero-stat-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 36px;
    font-weight: 800;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 4px;
  }

  .hero-stat-label {
    font-size: 12px;
    color: rgba(255,255,255,0.55);
    font-weight: 500;
    letter-spacing: 0.3px;
  }

  /* ── TOOLS SECTION ── */
  .section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 2.5rem;
  }

  .section-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 36px;
    font-weight: 800;
    color: var(--navy);
    text-transform: uppercase;
    margin-bottom: 2.5rem;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .tool-card {
    background: var(--white);
    border: 1.5px solid var(--gray-100);
    border-radius: 12px;
    padding: 28px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    position: relative;
    overflow: hidden;
  }

  .tool-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--gold);
    transform: scaleX(0);
    transition: transform 0.2s;
    transform-origin: left;
  }

  .tool-card:hover {
    border-color: rgba(232,160,32,0.3);
    box-shadow: 0 8px 30px rgba(27,43,107,0.12);
    transform: translateY(-3px);
  }

  .tool-card:hover::before { transform: scaleX(1); }

  .tool-icon {
    width: 44px;
    height: 44px;
    background: var(--navy);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
  }

  .tool-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 20px;
    font-weight: 800;
    color: var(--navy);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .tool-desc {
    font-size: 13px;
    color: var(--gray-600);
    line-height: 1.55;
    flex: 1;
  }

  .tool-link {
    font-size: 12px;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: 0.5px;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  /* ── PRIORITIES ── */
  .priorities-bg {
    background: var(--navy);
    padding: 4rem 0;
  }

  .priorities-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 0;
  }

  .priority-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 28px;
    transition: background 0.2s;
  }

  .priority-card:hover { background: rgba(255,255,255,0.09); }

  .priority-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 48px;
    font-weight: 900;
    color: rgba(232,160,32,0.2);
    line-height: 1;
    margin-bottom: 8px;
  }

  .priority-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 22px;
    font-weight: 800;
    color: var(--white);
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .priority-desc {
    font-size: 13px;
    color: rgba(255,255,255,0.55);
    line-height: 1.6;
  }

  .priorities-bg .section-title { color: var(--white); }

  /* ── MISSION ── */
  .mission-strip {
    background: var(--gold);
    padding: 2.5rem;
    text-align: center;
  }

  .mission-strip p {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(18px, 3vw, 28px);
    font-weight: 700;
    color: var(--navy);
    max-width: 800px;
    margin: 0 auto;
    line-height: 1.3;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* ── TEAM ── */
  .team-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .team-card {
    background: var(--white);
    border: 1.5px solid var(--gray-100);
    border-radius: 12px;
    padding: 24px 20px;
    text-align: center;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .team-card:hover {
    box-shadow: 0 6px 24px rgba(27,43,107,0.1);
    transform: translateY(-2px);
  }

  .team-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--navy);
    margin: 0 auto 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 22px;
    font-weight: 800;
    color: var(--gold);
    border: 2.5px solid var(--gold);
  }

  .team-name {
    font-weight: 700;
    font-size: 14px;
    color: var(--navy);
    margin-bottom: 4px;
  }

  .team-role {
    font-size: 11px;
    color: var(--gray-400);
    text-transform: uppercase;
    letter-spacing: 0.8px;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .team-region {
    font-size: 11px;
    color: var(--gray-400);
    margin-bottom: 12px;
  }

  .team-li {
    font-size: 11px;
    font-weight: 700;
    color: var(--gold);
    text-decoration: none;
    letter-spacing: 0.5px;
    border: 1.5px solid var(--gold);
    padding: 4px 10px;
    border-radius: 4px;
    display: inline-block;
    transition: background 0.15s, color 0.15s;
  }

  .team-li:hover { background: var(--gold); color: var(--navy); }

  /* ── FOOTER ── */
  .site-footer {
    background: var(--navy-dark);
    padding: 2rem 2.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 2px solid var(--gold);
  }

  .site-footer p {
    font-size: 12px;
    color: rgba(255,255,255,0.35);
  }

  .footer-badge {
    font-size: 11px;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: 1px;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-visual { display: none; }
    .tools-grid, .priorities-grid, .team-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 640px) {
    .site-header { padding: 0 1rem; }
    .hero { padding: 3rem 1.5rem; }
    .section { padding: 3rem 1.5rem; }
    .tools-grid, .priorities-grid, .team-grid { grid-template-columns: 1fr; }
    .hero-stat-row { grid-template-columns: 1fr 1fr; }
  }
</style>
</head>
